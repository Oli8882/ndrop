<?xml version="1.0" encoding="utf-8"?>
<!--
    NDrop — Android Manifest
    Signature: Olii-8882
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- NFC -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature android:name="android.hardware.nfc" android:required="true" />

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Haptics / Vibration -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Notifications (parking proximity alerts) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service for the countdown timer -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:name=".NDropApp"
        android:allowBackup="true"
        android:icon="@drawable/ndrop_icon"
        android:roundIcon="@drawable/ndrop_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.NDrop.Splash">

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Timer background service -->
        <service
            android:name=".service.TimerForegroundService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="Timer countdown" />
        </service>

        <!-- Home Screen Widget -->
        <receiver
            android:name=".ui.widget.ParkingWidgetReceiver"
            android:exported="true"
            android:label="NDrop Parking">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/parking_widget_info" />
        </receiver>

        <!-- FileProvider for GPX export and Drop Card image sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

    <!-- API 30+ package visibility: lets resolveActivity() find an installed maps app
         for geo: links (ShareHelper.openInMaps) instead of silently falling through
         to the browser fallback. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
    </queries>

</manifest>
